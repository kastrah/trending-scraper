# Copy this file to .env and fill in the values you have.
# Most credentials are auto-extracted by scripts/extract_cookies.py.
# Uncomment and set only what you need.

# ── Bright Data Web Unlocker ──────────────────────────────────────────────────
# Used as a proxy fallback when platforms block direct requests.
# Get a key: brightdata.com → Proxies & Scraping → Web Unlocker → API
# BRIGHT_DATA_API_KEY=
# BRIGHT_DATA_ZONE=web_unlocker1

# ── Reddit ────────────────────────────────────────────────────────────────────
# Option A: browser cookie — auto-filled by extract_cookies.py (preferred)
# REDDIT_TOKEN_V2=
# Option B: OAuth client credentials — create at reddit.com/prefs/apps
# REDDIT_CLIENT_ID=
# REDDIT_SECRET=

# ── X / Twitter ───────────────────────────────────────────────────────────────
# Auto-filled by extract_cookies.py. User timelines work without these
# (syndication API is public). Only needed for authenticated endpoints.
# X_AUTH_TOKEN=
# X_CT0=

# ── Instagram ─────────────────────────────────────────────────────────────────
# Auto-filled by extract_cookies.py after logging into instagram.com in Chrome.
# INSTAGRAM_SESSION_ID=
# INSTAGRAM_DS_USER_ID=
# INSTAGRAM_CSRF_TOKEN=

# ── TikTok ────────────────────────────────────────────────────────────────────
# Auto-filled by extract_cookies.py after logging into tiktok.com in Chrome.
# Expires after a few weeks — re-run extract_cookies.py when results drop to 0.
# TIKTOK_MS_TOKEN=
# TIKTOK_SESSION_ID=
# Set to 1 on local Mac for headed (visible) browser during debugging:
# TIKTOK_HEADED=1

# ── YouTube ───────────────────────────────────────────────────────────────────
# Optional. Without a key, yt-dlp search is used as a free fallback.
# Get a key: console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
# Free quota: 10,000 units/day. videos.list costs 1 unit per call.
# YOUTUBE_API_KEY=

# ── Telegram alerts ───────────────────────────────────────────────────────────
# Optional. Enables failure alerts and daily scrape summaries.
# Create a bot via @BotFather on Telegram, then get your chat ID from @userinfobot.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
